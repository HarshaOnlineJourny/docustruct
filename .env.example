# Copy to .env on the production host. Never commit the real .env.

# What port the Node process listens on internally. nginx proxies 443 -> here.
PORT=4000
NODE_ENV=production

# Encryption key for AI provider API keys at rest. MUST be set in production.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
DOCUSTRUCT_ENC_KEY=replace-me-with-a-long-random-string

# Optional: point at a local Ollama for free LLM calls.
# OLLAMA_HOST=http://127.0.0.1:11434
